# ─── Setu UPI Deeplinks (REQUIRED) ───
#
# All of these must be set for UPI payments to work. Sign up on Setu Bridge
# (https://bridge.setu.co), complete merchant KYC, create a UPI Deeplinks
# scheme, and copy the values from the dashboard.

# Sandbox: https://uat.setu.co   Production: https://prod.setu.co
SETU_BASE_URL=https://uat.setu.co

# OAuth client credentials from Bridge → Settings → API Keys
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=

# Product instance id (the deeplinks scheme you created on Bridge)
SETU_SCHEME_ID=

# Your platform's settlement bank account — Setu sends collected money here
# before splitting to vendor accounts.
SETU_PLATFORM_ACCOUNT_ID=
SETU_PLATFORM_IFSC=

# HMAC-SHA256 secret used to verify x-setu-signature on webhook callbacks.
# Configure the same value in Bridge → Webhooks → Signing secret.
SETU_WEBHOOK_SECRET=

# ─── Reconciliation cron (optional) ───
# If set, /api/payments/reconcile requires header `x-cron-key: <this value>`.
RECONCILE_CRON_KEY=
